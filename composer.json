{
    "name": "amjadiqbal/laralink",
    "description": "Local-First Package Manager for Laravel – link, develop, and publish Composer packages with Artisan commands",
    "homepage": "https://github.com/amjadiqbal/laralink",
    "type": "library",
    "keywords": [
        "laravel",
        "package-manager",
        "local-development",
        "composer",
        "artisan",
        "developer-tools"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Amjad Iqbal",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.0",
        "illuminate/console": "^9.0|^10.0|^11.0|^12.0",
        "illuminate/filesystem": "^9.0|^10.0|^11.0|^12.0",
        "illuminate/support": "^9.0|^10.0|^11.0|^12.0",
        "symfony/process": "^6.0|^7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^7.0|^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Amjadiqbal\\Laralink\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Amjadiqbal\\Laralink\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Amjadiqbal\\Laralink\\LaralinkServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "config": {
        "sort-packages": true
    },
    "prefer-stable": true
}
